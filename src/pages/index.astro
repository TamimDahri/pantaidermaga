---
import BaseLayout from '../layouts/BaseLayout.astro';
import { timeline, evidence, locations, sources } from '../data/site';
import PetitionCounter from "../components/PetitionCounter.astro";
import PetitionForm from "../components/PetitionForm.astro";
import "../styles/petition.css";
import RecentSignatures from "../components/RecentSignatures.astro";
---

<BaseLayout title="Pantai Dermaga — Muzium Digital" description="Muzium digital sejarah Pantai Dermaga, Tanjung Kemuning dan Port Dickson.">
  <header class="site-header" data-header>
    <a class="brand" href="#top" aria-label="Pantai Dermaga">Pantai Dermaga</a>
    <nav class="desktop-nav" aria-label="Navigasi utama">
      <a href="#sejarah">Sejarah</a>
      <a href="#galeri">Galeri</a>
      <a href="#sumber">Sumber</a>
      <a href="#petisyen">Petisyen</a>
    </nav>
    <button class="menu-button" data-menu-button aria-label="Buka menu">☰</button>
  </header>

  <nav class="mobile-nav" data-mobile-nav aria-label="Navigasi mudah alih">
    <a href="#sejarah">Sejarah</a>
    <a href="#galeri">Galeri</a>
    <a href="#sumber">Sumber</a>
    <a href="#petisyen">Petisyen</a>
  </nav>

  <main id="top">
    <section class="hero" id="sejarah">
      <div class="hero-bg" aria-hidden="true"></div>
      <div class="container hero-grid">
        <div class="hero-copy reveal">
          <p class="pill">Sejarah yang dilupakan</p>
          <h1>Sebelum Port Dickson, kawasan ini dikenali sebagai <span>Tanjung Kemuning.</span></h1>
          <p class="lead">Sebuah muzium digital untuk mengangkat semula sejarah pesisir Pantai Dermaga melalui peta lama, rekod arkib, tokoh tempatan dan memori komuniti.</p>
          <div class="actions">
            <a class="btn primary" href="#galeri">Terokai bukti</a>
            <a class="btn secondary" href="#petisyen">Sokong petisyen</a>
          </div>
        </div>
        <figure class="portrait reveal">
          <img src="/images/hero/raja-bot.png" alt="Ilustrasi Raja Bot memegang dokumen sejarah" />
          <figcaption>Raja Bot dan perubahan landskap Lukut–Port Dickson.</figcaption>
        </figure>
      </div>
    </section>

    <section class="intro section-pad">
      <div class="container narrow reveal">
        <p class="kicker">Soalan utama</p>
        <h2>Jika bukan Port Dickson, apakah nama dan cerita asal kawasan ini?</h2>
        <p>Projek ini menyusun sejarah yang lebih kemas: bukan sekadar menukar nama, tetapi menjelaskan lapisan sejarah Melayu, laluan perdagangan, tokoh Lukut dan perubahan yang berlaku selepas campur tangan British.</p>
      </div>
    </section>

    <section class="section-pad alt" id="galeri">
      <div class="container">
        <div class="section-heading reveal">
          <p class="kicker">Galeri bukti</p>
          <h2>Bahan visual dan dokumen yang menyokong penjenamaan.</h2>
          <p>Sumber penuh, imbasan dokumen, nota arkib dan pautan rujukan.</p>
        </div>
        <div class="evidence-layout">
          <article class="map-card reveal">
            <img src="/images/maps/1875-map.jpg" alt="Peta lama kawasan Linggi dan Lukut" />
            <div>
              <p class="pill dark">Peta lama</p>
              <h3>Linggi, Lukut dan jaringan pesisir</h3>
              <p>Peta lama menjadi latar visual utama untuk menunjukkan bahawa kawasan ini mempunyai sejarah yang lebih panjang daripada nama kolonial Port Dickson.</p>
            </div>
          </article>
          <div class="evidence-list">
            {evidence.map((item) => (
              <article class="info-card reveal">
                <span>{item.meta}</span>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section-pad timeline-section">
      <div class="container">
        <div class="section-heading centered reveal">
          <p class="kicker">Kronologi</p>
          <h2>Perjalanan sejarah Pantai Dermaga.</h2>
        </div>
        <div class="timeline">
          {timeline.map((item) => (
            <article class="timeline-item reveal">
              <div class="time">{item.year}</div>
              <div class="node" aria-hidden="true"></div>
              <div class="timeline-card">
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section-pad raja">
      <div class="identity-bg">
        <img
  src="/images/people/islah-wahyudi-bg.jpg"
  alt="Islah Wahyudi"
/>
      </div>
      <div class="container raja-grid">
        <div class="reveal">
          <p class="kicker">Tokoh</p>
          <h2>Randuk: Pejuang Identiti Kebangsaan.</h2>
          <p>Islah Wahyudi atau lebih dikenali sebagai Randuk merangkap Pengerusi Pertubuhan Pemerkasaan Identiti Malaysia adalah seorang aktivis yang telah lama memperjuangkan identiti sebenar Malaysia terutamanya penjenamaan nama di tempat kelahiran beliau sendiri.</p>
          <div class="stat-grid">
            <div><strong>Randuk</strong><span>Islah Wahyudi</span></div>
            <div><strong>Identiti Malaysia</strong><span>Anak Watan Pantai Dermaga</span></div>
          </div>
        </div>
        <div class="quote-card reveal">
          <p>“Sejarah tanah ini bukan bermula dengan Dickson. Tindakan Gabenor British itu yang merampas Tanjung Kemuning lalu menukarkan nama kepada Port Dickson sekitar tahun 1889 telah menyebabkan Kampung Melayu Bahasa Kapor lenyap.”</p>
        </div>
      </div>
    </section>

    <section class="section-pad sources-gallery-section" id="sumber">
  <div class="container">
    <div class="sources-header reveal">
      <div>
        <p class="kicker">Sumber</p>
        <h2>Galeri Sumber.</h2>
      </div>

      <p>
        Koleksi rujukan visual, peta lama, arkib dan bahan komuniti berkaitan
        Pantai Dermaga dan kawasan sekitarnya.
      </p>
    </div>

    <div class="sources-carousel-wrap">
      <button class="gallery-arrow gallery-prev" type="button" aria-label="Sebelum">
        ‹
      </button>

      <div class="sources-image-scroll" data-sources-scroll>
        {sources.map((item) => (
          <figure class="source-image-card reveal">
            <img src={item.image} alt={item.title} loading="lazy" />
          </figure>
        ))}
      </div>

      <button class="gallery-arrow gallery-next" type="button" aria-label="Seterusnya">
        ›
      </button>
    </div>

    <p class="drag-hint">☝️ Seret untuk melihat lebih banyak</p>
  </div>
</section>

    <section class="section petition-section" id="petisyen">
  <div class="section-heading">
    <span class="eyebrow">Petisyen Rasmi</span>
    <h2>Penjenamaan Semula Nama Pantai Dermaga</h2>
    <p>Sertai sokongan orang ramai untuk memelihara sejarah kawasan ini.</p>
  </div>

  <PetitionCounter />
  <PetitionForm />
  <RecentSignatures />
</section>

    <section class="section-pad places">
      <div class="container">
        <div class="section-heading centered reveal">
          <p class="kicker">Lokasi berkaitan</p>
          <h2>Peta naratif lapangan.</h2>
        </div>
        <div class="places-grid">
          {locations.map((item) => (
            <article class="place-card reveal">
              <span>{item.year}</span>
              <h3>{item.name}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container footer-inner">
      <strong>Pantai Dermaga</strong>
      <span>© 2026 Muzium Digital. Dibina untuk memulihara sejarah tempatan.</span>
    </div>
  </footer>
  <script>
  import "../scripts/sources-gallery";
</script>
</BaseLayout>
